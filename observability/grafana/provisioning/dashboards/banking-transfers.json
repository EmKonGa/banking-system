{
  "uid": "banking-transfers",
  "title": "Banking — Transfer Latency & DB Contention",
  "tags": ["banking", "transfers", "contention"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "type": "row",
      "title": "Transfer latency (hot-row early warning)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "Transfer p99 latency",
      "description": "p99 of the two transfer hops. A rising p99 on a low request rate is the classic signal that transfers are serializing on a hot account row.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"payment-service\", uri=\"/api/payments/transfer\"}[$__rate_interval])))",
          "legendFormat": "payment /transfer (outer)"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"account-service\", uri=\"/internal/accounts/execute-transfer\"}[$__rate_interval])))",
          "legendFormat": "account /execute-transfer (locked txn)"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transfer p95 / p50 latency (account locked txn)",
      "description": "Lower percentiles for the locked debit/credit transaction. Divergence between p50 and p99 indicates a subset of requests queueing behind a lock.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"account-service\", uri=\"/internal/accounts/execute-transfer\"}[$__rate_interval])))",
          "legendFormat": "p95"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, sum by (le) (rate(http_server_requests_seconds_bucket{application=\"account-service\", uri=\"/internal/accounts/execute-transfer\"}[$__rate_interval])))",
          "legendFormat": "p50"
        }
      ]
    },
    {
      "type": "row",
      "title": "DB connection contention (lock-wait proxy)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 10 },
      "collapsed": false
    },
    {
      "type": "timeseries",
      "title": "HikariCP connections pending",
      "description": "Threads waiting for a DB connection. A blocked (row-locked) transaction holds its connection, so a hot account shows up here as sustained pending > 0. Postgres lock waits aren't scraped directly (no postgres_exporter), so this is the best available proxy.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 0, "y": 11 },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_pending{application=~\"account-service|payment-service\"}",
          "legendFormat": "{{application}} — {{pool}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "HikariCP connection acquire time (max)",
      "description": "Max time a thread waited to acquire a pooled connection. Rising acquire time on account-service correlates with transfers queueing on locks.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 9, "w": 12, "x": 12, "y": 11 },
      "fieldConfig": {
        "defaults": { "unit": "s", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "hikaricp_connections_acquire_seconds_max{application=~\"account-service|payment-service\"}",
          "legendFormat": "{{application}} — {{pool}}"
        }
      ]
    },
    {
      "type": "timeseries",
      "title": "Transfer throughput (req/s)",
      "description": "Request rate for the transfer endpoints. Read p99 together with this: high p99 at low throughput on a single account is the hot-row signature.",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": { "unit": "reqps", "custom": { "drawStyle": "line", "lineWidth": 2, "fillOpacity": 10 } },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum by (application) (rate(http_server_requests_seconds_count{uri=~\"/api/payments/transfer|/internal/accounts/execute-transfer\"}[$__rate_interval]))",
          "legendFormat": "{{application}}"
        }
      ]
    }
  ]
}
