# Copy this file to .env and fill in your values
# Docker Compose reads .env automatically

# PostgreSQL (compose reads DB_USER / DB_PASSWORD)
DB_USER=banking_user
DB_PASSWORD=banking_pass

# Redis
REDIS_PASSWORD=redis_pass

# JWT (generate a strong secret: openssl rand -base64 64)
# Startup fails if this is left as a placeholder.
JWT_SECRET=your-256-bit-secret-here-change-this-in-production
JWT_ACCESS_EXPIRATION_MS=300000
JWT_REFRESH_EXPIRATION_MS=900000
# Absolute session cap: full re-login after 8h even if continuously active.
JWT_MAX_SESSION_MS=28800000
# For quick token-expiry testing, use short TTLs instead (30s access / 2min refresh),
#JWT_ACCESS_EXPIRATION_MS=30000
#JWT_REFRESH_EXPIRATION_MS=120000

# Internal service-to-service secret guarding /internal/** (openssl rand -base64 32)
# Startup fails if this is left as the placeholder 'internal-secret-change-me'.
INTERNAL_SECRET=change-me-to-a-strong-random-value
